@startuml
skinparam SwimlaneWidth 200
skinparam ActivityBorderColor #333333
skinparam ActivityBackgroundColor #FFFFFF
skinparam ArrowColor #555555
skinparam FontName "Segoe UI"
skinparam NoteBackgroundColor #FFFFCC
skinparam NoteBorderColor #999999

title Расчёт MRP и формирование плана закупок (v4 - Final)

note right
  **Retry Policy (для всех внешних вызовов):**
  - Timeout: 5 сек (GET), 10 сек (POST)
  - Max retries: 3
  - Backoff: 2^retry_count секунд (2с → 4с → 8с)
  - При исчерпании попыток: fallback или ошибка
end note

|Web Client|
start
:Форма "Расчёт MRP":\n- Продукты, количество, период\n- Генерация idempotency_key (UUID);
:POST /api/mrp/calculate\nX-Idempotency-Key: {uuid};

|API Gateway|
:Аутентификация и авторизация:\n- Извлечение JWT токена\n- Валидация токена\n- Проверка прав доступа\n- Базовая валидация JSON;

if (Проверки пройдены?) then (Нет)
  :HTTP 401/403/400;
  detach
else (Да)
  :Маршрутизация → MRP Service;
endif

|MRP Service|
:Получение запроса;

' ==================== ИДЕМПОТЕНТНОСТЬ ====================
if (idempotency_key существует в БД?) then (Да)
  :Возврат кэшированного результата;
  :HTTP 200 OK (cached);
  detach
else (Нет)
endif

:Валидация бизнес-правил:\n- Проверка существования продуктов\n- Валидация периода планирования\n- Проверка корректности количеств;

if (Валидация OK?) then (Нет)
  :HTTP 400 Bad Request;
  detach
else (Да)
endif

:Начало транзакции (BEGIN);
:Создание Плана производства\nи Расчёта MRP\n(атомарная операция);

if (Сохранение успешно?) then (Нет)
  :Откат транзакции (ROLLBACK);
  :HTTP 500 Internal Server Error;
  detach
else (Да)
  :Фиксация (COMMIT);
endif

note right
  **Отмена расчёта:**
  Пользователь может отправить
  DELETE /api/mrp/calculate/{id}
  для установки флага cancellation_requested
end note

' ==================== ЗАГРУЗКА BOM ====================
:Инициализация:\n- materials_list = []\n- failed_products = [];

repeat
  if (Расчет отменен?) then (Да)
    :Обновление статуса → CANCELLED;
    :HTTP 200 OK {"status": "CANCELLED"};
    detach
  else (Нет)
  endif

  :Выбор продукта из плана;

  |BOM Service|
  :GET /api/bom/specifications/{id}\n(с retry policy);

  if (Спецификация найдена?) then (Да)
    :Загрузка активной спецификации;
    :Загрузка компонентов спецификации;
    :HTTP 200 OK + components[];

    |MRP Service|
    :Расчёт потребности:\nтребуемое кол-во = планируемое кол-во × кол-во компонентов × (1 + %потерь/100);
    :Агрегация в materials_list;
  else (Нет)
    |MRP Service|
    :Добавление в лист проваленный_расчт[];
  endif

repeat while (Есть еще продукты для расчета?) is (Да)
->Нет;

|MRP Service|

' ==================== РАСЧЁТ ДЕФИЦИТОВ ====================
:Инициализация:\n- deficits_list(создание массива) = []\n- urgent_count(обнуление счетчика срочных заказов) = 0;

repeat
  if (Есть ли запрос отмены расчета?) then (Да)
    :Обновление статуса → CANCELLED;
    :HTTP 200 OK {"status": "CANCELLED"};
    detach
  else (Нет)
  endif

  :Выбор материала из materials_list;

  |WMS Service|
  :GET /api/wms/stock/{id}\n(с retry policy);
  :Расчёт текущих остатков по складам;
  :HTTP 200 OK + available_qty;

  |MRP Service|
  :Расчет дефицита = требуемое -кол-во - доступное кол-во;

  if (Дефицит > 0?) then (Да)
    :Расчет даты заказа = дата заказа - требуемое время;
    :Определение приоритета = (дата заказа < текущая дата) ? HIGH : MEDIUM;
    if (приоритет = HIGH?) then (Да)
      :обновить счетчик заказов;
    else (Нет)
    endif
    :Добавление в лист дефицита;
  else (Нет)
  endif

repeat while (Есть материалы?) is (Да)
->Нет;

|MRP Service|

' ==================== СОХРАНЕНИЕ ====================
:Начало транзакции (BEGIN);
:Обновление статуса расчёта → COMPLETED\n(total_materials, total_deficit, urgent_count);

if (Обновление успешно?) then (Нет)
  :Откат транзакции (ROLLBACK);
  :HTTP 500 Internal Server Error;
  detach
else (Да)
  :Фиксация (COMMIT);
endif

:Сохранение результатов в MongoDB:\n- Заголовок расчёта (mrp_results)\n- Детали по материалам (mrp_result_items[]);

' ==================== ПЛАН ЗАКУПОК ====================
if (Есть ли записи в листе дефицита?) then (Да)
  :Группировка дефицитов по поставщикам;

  fork
    |MRP Service|
    |Procurement Service|
    :POST /api/procurement/requests\n(с retry policy);

    :Начало транзакции (BEGIN);
    :Создание заявок на закупку;
    :Создание событий для Outbox;

    if (Сохранение успешно?) then (Да)
      :Фиксация (COMMIT);
      :HTTP 201 Created;
      |MRP Service|
      :Сервер = true;
    else (Нет)
      :Откат транзакции (ROLLBACK);
      |MRP Service|
      :procurement_success = false;
    endif

  fork again
    |️MRP Service|
    |Procurement Service|
    :GET /api/procurement/suppliers\n(с retry policy);
    :Загрузка данных о поставщиках;
    :HTTP 200 OK;
    |MRP Service|
    :suppliers_success = true;

  end fork

  |MRP Service|
if (Оба сервиса ответили успешно?) then (Да)
  :Установить статус: COMPLETED;
else if (Только заявки созданы?) then (Частично)
  :Установить статус: COMPLETED_WITH_WARNINGS;
  :Добавить предупреждение: "Данные о поставщиках недоступны";
else if (Только поставщики найдены?) then (Частично)
  :Установить статус: COMPLETED_WITH_WARNINGS;
  :Добавить предупреждение: "Заявки не созданы в Procurement";
else (Оба failed)
  :Установить статус: COMPLETED_WITH_ERRORS;
  :Добавить ошибку: "Сервисы недоступны";
endif

' ==================== ОТВЕТ ====================
|MRP Service|
:Начало транзакции (BEGIN);
:Создание события завершения\n(outbox_events);

if (Сохранение успешно?) then (Да)
  :Фиксация (COMMIT);
else (Нет)
  :Откат транзакции (ROLLBACK);
  note right: Событие не критично для ответа
endif

:Формирование Response:\n{mrpCalculationId, status, totalMaterials,\ntotalDeficit, urgentCount, hasMaterialShortage,\npurchaseRequests[], suppliers[], warnings[], errors[]};

:HTTP 200 OK;

|API Gateway|
:Передача ответа клиенту;

|Web Client|
:Отображение результата:\n- Статус расчёта\n- Предупреждения (если есть)\n- Список дефицитов\n- План закупок;

if (Есть дефициты И нажал "Утвердить"?) then (Да)
  :POST /api/procurement/approve;
  |API Gateway|
  :Аутентификация и маршрутизация;
  |Procurement Service|
  :Обновление статуса заявок → APPROVED;
  :HTTP 200 OK;
  |Web Client|
  :Показ: "План утверждён";
else (Нет)
endif

stop

' ==================== ОТМЕНА ====================
floating note left
  **Endpoint отмены:**
  DELETE /api/mrp/calculate/{id}

  MRP Service:
  Установка флага cancellation_requested = true

  HTTP 202 Accepted
end note

' ==================== OUTBOX WORKER ====================
floating note right
  **Фоновый процесс (Outbox Worker):**

  Каждые 2 секунды:
  1. Выборка необработанных событий (LIMIT 100)

  2. Для каждого события:
     - POST /api/notifications/send
     - POST /api/analytics/events

  3. При успехе:
     Обновление processed_at = NOW()

  4. При ошибке (retry < 3):
     Обновление next_retry_at

  5. При исчерпании попыток:
     → Dead Letter Queue
end note

@enduml